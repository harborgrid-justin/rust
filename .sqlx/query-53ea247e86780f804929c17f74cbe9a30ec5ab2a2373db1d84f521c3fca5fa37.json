  "query": "\n        SELECT tm.id, tm.user_id, tm.role, tm.added_by, tm.added_at,\n               u.username, u.full_name\n        FROM team_members tm\n        INNER JOIN users u ON tm.user_id = u.id\n        WHERE tm.team_id = ?1\n        ORDER BY tm.added_at ASC\n        ",
