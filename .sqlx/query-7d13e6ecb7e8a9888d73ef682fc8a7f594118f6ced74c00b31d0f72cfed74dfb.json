  "query": "\n        SELECT t.id, t.name, t.description, t.created_by, t.created_at, t.updated_at,\n               COUNT(tm.id) as member_count\n        FROM teams t\n        LEFT JOIN team_members tm ON t.id = tm.team_id\n        WHERE t.id = ?1\n        GROUP BY t.id\n        ",
