  "query": "\n                SELECT a.id, a.user_id, a.action, a.entity_type, a.entity_id, a.details, \n                       a.ip_address, a.user_agent, a.created_at, u.username\n                FROM activities a\n                INNER JOIN users u ON a.user_id = u.id\n                ORDER BY a.created_at DESC\n                LIMIT ?1 OFFSET ?2\n                ",
